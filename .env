# =============================================================================
# IBM watsonx Orchestrate — Startup Blueprint Generator Agent
# Copy this file to .env and fill in your credentials
# =============================================================================

# ── IBM watsonx.ai Credentials ───────────────────────────────────────────────
# Obtain from: https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY=PNepDu_glEzcjSiTOipX3Xqxj0me7qqrg_nW7nnR6Tko

# watsonx.ai instance URL (Dallas example shown)
# Options: https://us-south.ml.cloud.ibm.com
#          https://eu-de.ml.cloud.ibm.com
#          https://eu-gb.ml.cloud.ibm.com
#          https://jp-tok.ml.cloud.ibm.com
WATSONX_URL=https://au-syd.ml.cloud.ibm.com

# watsonx.ai Project ID (from your watsonx.ai project settings)
WATSONX_PROJECT_ID=43d3a275-8061-4469-91a4-c14a458c647a

# ── IBM Granite Model Configuration ─────────────────────────────────────────
# Primary model for blueprint generation
GRANITE_MODEL_ID=meta-llama/llama-3-3-70b-instruct
GRANITE_INSTRUCT_MODEL_ID=meta-llama/llama-3-3-70b-instruct
GRANITE_EMBEDDING_MODEL_ID=ibm/slate-125m-english-rtrvr-v2

# ── IBM Watson Discovery (RAG Knowledge Base) ────────────────────────────────
# IBM Cloud Lite tier — Free Discovery instance
#WATSON_DISCOVERY_API_KEY=
#WATSON_DISCOVERY_URL=
#WATSON_DISCOVERY_PROJECT_ID=
#WATSON_DISCOVERY_VERSION=2023-03-31

# ── IBM Watson Assistant (Optional: Conversational Interface) ─────────────────
WATSON_ASSISTANT_API_KEY=your_assistant_api_key_here
WATSON_ASSISTANT_URL=https://api.us-south.assistant.watson.cloud.ibm.com
WATSON_ASSISTANT_ID=your_assistant_id_here
WATSON_ASSISTANT_VERSION=2023-06-15

# ── Agent Behavior Settings ───────────────────────────────────────────────────
# Temperature for generation (0.0 = deterministic, 1.0 = creative)
AGENT_TEMPERATURE=0.7

# Maximum tokens for the full blueprint output
AGENT_MAX_TOKENS=4096

# Number of RAG documents to retrieve per query
RAG_TOP_K=5

# Minimum relevance score threshold for RAG results (0.0 – 1.0)
RAG_MIN_SCORE=0.65

# ── Output Settings ───────────────────────────────────────────────────────────
# Directory where generated blueprints are saved
OUTPUT_DIR=./output

# Blueprint output format: "markdown" | "json" | "both"
OUTPUT_FORMAT=both

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: "error" | "warn" | "info" | "debug"
LOG_LEVEL=info
LOG_FILE=./logs/agent.log
