# IBM watsonx Startup Blueprint Generator — Runtime
#
# .env.render (or Render/Railway/Heroku environment settings)
# Do NOT commit this file — add these as environment variables in your
# hosting dashboard or via platform secrets.

WATSONX_API_KEY=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=

GRANITE_MODEL_ID=meta-llama/llama-3-1-8b
AGENT_TEMPERATURE=0.7
AGENT_MAX_TOKENS=4096
RAG_TOP_K=5
RAG_MIN_SCORE=0.65
OUTPUT_DIR=/tmp/blueprints
OUTPUT_FORMAT=json
LOG_LEVEL=info
LOG_FILE=/tmp/logs/agent.log
PORT=3000
