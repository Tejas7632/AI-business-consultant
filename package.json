{
  "name": "startup-blueprint-agent",
  "version": "1.0.0",
  "description": "AI-Powered Startup Blueprint Generator Agent using IBM watsonx Orchestrate, IBM Granite models, and RAG",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "startup-blueprint": "./build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "start:web": "node build/web/server-entry.js",
    "dev": "tsx src/index.ts",
    "dev:web": "tsx src/web/server-entry.ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=tests/",
    "lint": "eslint src/**/*.ts",
    "clean": "rimraf build"
  },
  "dependencies": {
    "@ibm-cloud/watsonx-ai": "^1.2.0",
    "ibm-watson": "^9.1.0",
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "inquirer": "^10.1.5",
    "commander": "^12.1.0",
    "zod": "^3.23.8",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "marked": "^13.0.2",
    "cli-table3": "^0.6.5",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/uuid": "^10.0.0",
    "@types/inquirer": "^9.0.7",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "typescript": "^5.5.3",
    "tsx": "^4.15.7",
    "rimraf": "^5.0.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [".ts"],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "useESM": true }]
    }
  },
  "files": ["build", "knowledge-base"]
}
